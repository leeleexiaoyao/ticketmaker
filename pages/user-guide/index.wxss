.guide-page {
  height: 100vh;
  box-sizing: border-box;
  padding: 18rpx 24rpx 36rpx;
  background: #101114;
}

.guide-hero {
  padding: 14rpx 8rpx 20rpx;
}

.hero-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #f3f4f6;
}

.hero-subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #9aa2b0;
}

.guide-section {
  background: rgba(24, 26, 31, 0.92);
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 18rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  box-shadow: 0 16rpx 34rpx rgba(0, 0, 0, 0.38);
}

.guide-title {
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 14rpx;
  color: #f3f4f6;
}

.guide-text {
  font-size: 26rpx;
  color: #b1b8c4;
  margin-bottom: 10rpx;
  line-height: 1.62;
}

/* 主题维护说明：调整深色配色时，请同步更新下方浅色覆盖。 */
.theme-light.guide-page {
  background: #f4f7fc;
}

.theme-light .hero-title,
.theme-light .guide-title {
  color: #1b2538;
}

.theme-light .hero-subtitle {
  color: #6a7a90;
}

.theme-light .guide-section {
  background: rgba(255, 255, 255, 0.95);
  border: 1rpx solid rgba(26, 43, 70, 0.1);
  box-shadow: 0 16rpx 34rpx rgba(29, 49, 79, 0.12);
}

.theme-light .guide-text {
  color: #5d6d84;
}
