.preview-page {
  min-height: 100vh;
  padding-bottom: 36rpx;
  box-sizing: border-box;
  background: #101114;
  position: relative;
  overflow: hidden;
}

.top-nav,
.canvas-wrap,
.action-row {
  position: relative;
  z-index: 1;
}

.top-nav {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 28rpx;
  box-sizing: border-box;
  background: rgba(15, 16, 20, 0.82);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.08);
}

.back-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.06);
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-arrow {
  width: 18rpx;
  height: 18rpx;
  border-left: 4rpx solid #f3f4f6;
  border-bottom: 4rpx solid #f3f4f6;
  transform: rotate(45deg);
  margin-left: 8rpx;
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 40rpx;
  font-weight: 700;
  color: #f3f4f6;
}

.nav-space {
  width: 64rpx;
}

.preview-head {
  margin-top: 14rpx;
  padding: 0 34rpx;
}

.preview-title {
  font-size: 36rpx;
  color: #f3f4f6;
  font-weight: 700;
}

.preview-subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #8f97a6;
}

.canvas-wrap {
  display: flex;
  justify-content: center;
  margin-top: 16rpx;
}

.canvas-shell {
  padding: 14rpx;
  border-radius: 30rpx;
  background: rgba(24, 27, 33, 0.9);
  box-shadow: 0 20rpx 56rpx rgba(0, 0, 0, 0.48);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.preview-canvas {
  width: 640rpx;
  height: 1024rpx;
  border-radius: 24rpx;
  background: #15181e;
  box-shadow: inset 0 0 0 1rpx rgba(255, 255, 255, 0.08);
}

.preview-tip {
  margin: 24rpx 0 0;
  text-align: center;
  font-size: 23rpx;
  color: #8f97a6;
}

.action-row {
  margin-top: 24rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  padding: 0 30rpx;
}

.action-btn {
  width: 100%;
}
