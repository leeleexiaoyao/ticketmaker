.profile-page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 18rpx 28rpx 30rpx;
  display: flex;
  flex-direction: column;
  background: #101114;
}

.profile-header {
  padding: 30rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border-radius: 30rpx;
}

.avatar {
  width: 132rpx;
  height: 132rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #f4f5f7 0%, #cfd3da 100%);
  color: #111317;
  font-size: 60rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 28rpx rgba(0, 0, 0, 0.45);
}

.nickname {
  margin-top: 20rpx;
  font-size: 40rpx;
  color: #f3f4f6;
  font-weight: 700;
}

.header-subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #9199a8;
}

.feature-list {
  margin-top: 28rpx;
  border-radius: 24rpx;
  overflow: hidden;
}

.feature-item {
  min-height: 118rpx;
  display: flex;
  align-items: center;
  padding: 18rpx 24rpx;
  box-sizing: border-box;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.08);
}

.feature-item:last-child {
  border-bottom: none;
}

.item-hover {
  transform: scale(0.992);
  background: rgba(255, 255, 255, 0.06);
}

.item-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  position: relative;
  flex-shrink: 0;
}

.icon-delete {
  background: linear-gradient(145deg, #4d2f35 0%, #40272d 100%);
}

.icon-delete::before {
  content: '';
  position: absolute;
  left: 18rpx;
  top: 16rpx;
  width: 20rpx;
  height: 22rpx;
  border: 3rpx solid #ff8a8a;
  border-top: none;
  border-radius: 0 0 6rpx 6rpx;
}

.icon-delete::after {
  content: '';
  position: absolute;
  left: 14rpx;
  top: 10rpx;
  width: 28rpx;
  height: 4rpx;
  background: #ff8a8a;
  border-radius: 4rpx;
}

.icon-about {
  background: linear-gradient(145deg, #2f3a50 0%, #283245 100%);
}

.icon-about::before {
  content: 'i';
  position: absolute;
  left: 22rpx;
  top: 10rpx;
  font-size: 30rpx;
  line-height: 1;
  color: #9dc1ff;
  font-weight: 700;
}

.icon-guide {
  background: linear-gradient(145deg, #2b4238 0%, #24382f 100%);
}

.icon-guide::before {
  content: '?';
  position: absolute;
  left: 18rpx;
  top: 10rpx;
  font-size: 34rpx;
  line-height: 1;
  color: #92d8ae;
  font-weight: 700;
}

.icon-theme {
  background: linear-gradient(145deg, #3a3f56 0%, #2b3042 100%);
}

.icon-theme::before {
  content: '';
  position: absolute;
  width: 30rpx;
  height: 30rpx;
  border-radius: 50%;
  background: #f2f5ff;
  left: 13rpx;
  top: 13rpx;
  box-shadow: inset -8rpx -8rpx 0 0 #8fa2d8;
}

.item-copy {
  display: flex;
  flex-direction: column;
  margin-left: 18rpx;
  flex: 1;
}

.item-text {
  font-size: 30rpx;
  color: #f3f4f6;
  font-weight: 600;
}

.item-desc {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #9aa2b0;
}

.item-arrow {
  width: 18rpx;
  height: 18rpx;
  border-top: 3rpx solid #a3acba;
  border-right: 3rpx solid #a3acba;
  transform: rotate(45deg);
  margin-left: 8rpx;
}

.feature-theme-item {
  min-height: 130rpx;
}

.theme-switch {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 6rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.06);
  margin-left: 12rpx;
}

.theme-option {
  min-width: 84rpx;
  height: 50rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 500;
  color: #aeb7c6;
}

.theme-option.active {
  color: #101114;
  background: linear-gradient(135deg, #f5f5f7 0%, #cfd3da 100%);
}

.version-text {
  margin-top: auto;
  text-align: center;
  color: #9099a7;
  font-size: 24rpx;
  padding-bottom: 30rpx;
}

/* 主题维护说明：调整深色配色时，请同步更新下方浅色覆盖。 */
.theme-light.profile-page {
  background: #f3f6fc;
}

.theme-light .avatar {
  background: linear-gradient(145deg, #2a3548 0%, #141b27 100%);
  color: #f6f8fc;
  box-shadow: 0 16rpx 28rpx rgba(16, 29, 49, 0.2);
}

.theme-light .nickname {
  color: #1b2432;
}

.theme-light .header-subtitle {
  color: #667389;
}

.theme-light .feature-item {
  border-bottom: 1rpx solid rgba(27, 38, 57, 0.1);
}

.theme-light .item-hover {
  background: rgba(45, 66, 102, 0.06);
}

.theme-light .item-text {
  color: #1f2836;
}

.theme-light .item-desc {
  color: #68778e;
}

.theme-light .item-arrow {
  border-top-color: #62748f;
  border-right-color: #62748f;
}

.theme-light .theme-switch {
  background: rgba(43, 60, 88, 0.08);
}

.theme-light .theme-option {
  color: #5f7089;
}

.theme-light .theme-option.active {
  color: #f5f8ff;
  background: linear-gradient(135deg, #37485f 0%, #1f2d42 100%);
}

.theme-light .version-text {
  color: #6d7b90;
}
