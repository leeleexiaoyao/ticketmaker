.home-page {
  min-height: 100vh;
  padding: 0 24rpx 44rpx;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
  background: #131722;
}

.home-header,
.category-wrap,
.templates-card {
  position: relative;
  z-index: 1;
}

.home-header {
  padding: 18rpx 20rpx 6rpx;
}

.category-wrap {
  padding: 10rpx 6rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.category-tabs {
  display: flex;
  align-items: center;
  gap: 36rpx;
}

.category-item {
  position: relative;
  padding-bottom: 12rpx;
  font-size: 32rpx;
  color: #8991a1;
  font-weight: 500;
  transition: color 0.2s ease, transform 0.2s ease;
}

.category-item.active {
  color: #f4f5f7;
  font-weight: 700;
}

.category-item.active::after {
  content: '';
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 6rpx;
  border-radius: 6rpx;
  background: linear-gradient(90deg, #f2f3f6 0%, #aeb5c0 100%);
}

.tap-item.item-press {
  transform: scale(0.96);
}

.avatar-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  padding: 6rpx;
  box-sizing: border-box;
  background: linear-gradient(135deg, #2f3440 0%, #232730 100%);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-inner {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: radial-gradient(circle at 50% 35%, #f2f3f6 0 18rpx, #676f7f 20rpx, #444a58 100%);
}

.avatar-press {
  transform: scale(0.96);
}

.templates-card {
  margin-top: 18rpx;
  padding: 18rpx 0 0;
  overflow: hidden;
}

.template-swiper {
  height: 900rpx;
}

.template-item-wrap {
  height: 100%;
  display: flex;
  justify-content: center;
  align-items: flex-start;
  padding-top: 34rpx;
}

.template-card {
  width: 420rpx;
  padding: 12rpx;
  transform: scale(1);
  transition: transform 0.24s ease, opacity 0.24s ease;
  opacity: 0.82;
}

.template-card.selected {
  transform: scale(1.12);
  opacity: 1;
}

.template-card-press {
  transform: scale(1.06);
}

.preview-frame {
  height: 640rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #1c2027 0%, #171a21 100%);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  padding: 24rpx;
  box-sizing: border-box;
}

.preview-image-area {
  width: 100%;
  height: 376rpx;
  border-radius: 16rpx;
  background:
    radial-gradient(circle at 14% 18%, rgba(102, 114, 145, 0.36) 0, rgba(102, 114, 145, 0) 40%),
    radial-gradient(circle at 88% 86%, rgba(66, 74, 94, 0.5) 0, rgba(66, 74, 94, 0) 42%),
    #111419;
  border: 1rpx dashed rgba(255, 255, 255, 0.2);
}

.preview-text-group {
  margin-top: 26rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.preview-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #f4f5f7;
}

.preview-subtitle {
  font-size: 22rpx;
  color: #8d95a2;
}

.template-name {
  display: block;
  text-align: center;
  margin-top: 18rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #eff1f4;
}

.swiper-indicator-row {
  margin-top: 8rpx;
  display: flex;
  justify-content: center;
  gap: 14rpx;
}

.indicator-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 999rpx;
  background: #3c414d;
  transition: width 0.2s ease, background 0.2s ease;
}

.indicator-dot.active {
  width: 38rpx;
  background: linear-gradient(90deg, #f2f3f6 0%, #b1b7c2 100%);
}

.route-mask {
  position: fixed;
  inset: 0;
  background: rgba(12, 13, 16, 0.95);
  z-index: 99;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.route-loading {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(255, 255, 255, 0.16);
  border-top-color: #f2f3f6;
  animation: spin 0.8s linear infinite;
}

.route-text {
  margin-top: 18rpx;
  font-size: 24rpx;
  color: #a3aab7;
}

@keyframes spin {
  0% {
    transform: rotate(0deg);
  }
  100% {
    transform: rotate(360deg);
  }
}
