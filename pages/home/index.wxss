.home-page {
  min-height: 100vh;
  padding: 0 24rpx 44rpx;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
  background: #131722;
}

.home-header,
.category-wrap,
.templates-card {
  position: relative;
  z-index: 1;
}

.home-header {
  padding: 18rpx 20rpx 6rpx;
}

.category-wrap {
  padding: 10rpx 6rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.category-tabs {
  position: relative;
  display: flex;
  align-items: center;
  gap: 0;
  height: 72rpx;
}

.category-item {
  position: relative;
  width: 150rpx;
  text-align: center;
  font-family: 'TicketHomeTabFont', sans-serif;
  font-size: 28rpx;
  line-height: 56rpx;
  color: rgba(255, 255, 255, 0.6);
  font-weight: 400;
  transform: translateY(2rpx) scale(0.94);
  transition: color 0.24s ease, transform 0.24s ease, font-size 0.24s ease;
}

.category-item.active {
  font-size: 36rpx;
  color: #f4f5f7;
  font-weight: 500;
  transform: translateY(0) scale(1);
}

.category-indicator {
  position: absolute;
  left: 47rpx;
  bottom: 0;
  width: 56rpx;
  height: 4rpx;
  background: linear-gradient(90deg, #f2f3f6 0%, #aeb5c0 100%);
  transition: transform 0.24s ease;
}

.tap-item.item-press {
  transform: scale(0.96);
}

.avatar-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  padding: 6rpx;
  box-sizing: border-box;
  background: linear-gradient(135deg, #2f3440 0%, #232730 100%);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-inner {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: radial-gradient(circle at 50% 35%, #f2f3f6 0 18rpx, #676f7f 20rpx, #444a58 100%);
}

.avatar-press {
  transform: scale(0.96);
}

.templates-card {
  margin-top: 18rpx;
  padding: 18rpx 0 0;
  overflow: visible;
}

.template-swiper {
  height: auto;
}

.template-item-wrap {
  height: 100%;
  display: flex;
  justify-content: center;
  align-items: flex-start;
  padding-top: 34rpx;
}

.template-card {
  width: 75vw;
  padding: 0;
  transform: scale(0.88);
  transition: transform 0.24s ease, opacity 0.24s ease;
  opacity: 0.58;
}

.template-card.selected {
  transform: scale(1.08);
  opacity: 1;
}

.template-card-press {
  transform: scale(1.06);
}

.preview-frame {
  width: 100%;
  border-radius: 0;
  background: transparent;
  border: none;
  padding: 0;
  box-sizing: border-box;
  overflow: visible;
}

.preview-image-area {
  width: 100%;
  height: auto;
  display: block;
  border-radius: 0;
}

.route-mask {
  position: fixed;
  inset: 0;
  background: rgba(12, 13, 16, 0.95);
  z-index: 99;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.route-loading {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(255, 255, 255, 0.16);
  border-top-color: #f2f3f6;
  animation: spin 0.8s linear infinite;
}

.route-text {
  margin-top: 18rpx;
  font-size: 24rpx;
  color: #a3aab7;
}

@keyframes spin {
  0% {
    transform: rotate(0deg);
  }
  100% {
    transform: rotate(360deg);
  }
}

/* 主题维护说明：调整深色配色时，请同步更新下方浅色覆盖。 */
.theme-light.home-page {
  background: #f3f6fc;
}

.theme-light .category-item {
  color: rgba(0, 0, 0, 0.6);
}

.theme-light .category-item.active {
  color: #000;
}

.theme-light .category-indicator {
  background: linear-gradient(90deg, #202a39 0%, #455269 100%);
}

.theme-light .avatar-btn {
  background: linear-gradient(135deg, #ffffff 0%, #e9eef8 100%);
  border: 1rpx solid rgba(24, 38, 64, 0.12);
}

.theme-light .avatar-inner {
  background: radial-gradient(circle at 50% 35%, #55627a 0 18rpx, #b3bdce 20rpx, #8f9bb0 100%);
}

.theme-light .route-mask {
  background: rgba(238, 244, 252, 0.95);
}

.theme-light .route-loading {
  border: 6rpx solid rgba(53, 74, 106, 0.2);
  border-top-color: #334766;
}

.theme-light .route-text {
  color: #607088;
}
