.save-result-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 32rpx 40rpx;
  box-sizing: border-box;
  background: #101114;
}

.result-icon-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.result-icon {
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #47d79a 0%, #1fab73 100%);
  position: relative;
  box-shadow: 0 12rpx 30rpx rgba(36, 201, 135, 0.3);
}

.result-icon::before {
  content: '';
  position: absolute;
  left: 30rpx;
  top: 52rpx;
  width: 18rpx;
  height: 8rpx;
  border-left: 5rpx solid #ffffff;
  border-bottom: 5rpx solid #ffffff;
  transform: rotate(-45deg);
}

.result-icon::after {
  content: '';
  position: absolute;
  left: 42rpx;
  top: 46rpx;
  width: 32rpx;
  height: 8rpx;
  border-left: 5rpx solid #ffffff;
  border-bottom: 5rpx solid #ffffff;
  transform: rotate(-45deg);
}

.result-title {
  margin-top: 20rpx;
  font-size: 56rpx;
  font-weight: 700;
  color: #f3f4f6;
}

.result-subtitle {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #9aa2b0;
}

.preview-card {
  margin-top: 30rpx;
  width: 500rpx;
  padding: 16rpx;
  border-radius: 30rpx;
}

.preview-wrap {
  width: 100%;
  height: 740rpx;
  background: #15181e;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 20rpx;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.preview-image {
  width: 100%;
  height: 100%;
}

.preview-placeholder {
  color: #a1a8b6;
  font-size: 30rpx;
  text-align: center;
  padding: 0 20rpx;
}

.back-home-btn {
  width: 500rpx;
  margin-top: 44rpx;
}

/* 主题维护说明：调整深色配色时，请同步更新下方浅色覆盖。 */
.theme-light.save-result-page {
  background: #f4f7fc;
}

.theme-light .result-title {
  color: #1c2638;
}

.theme-light .result-subtitle {
  color: #66768f;
}

.theme-light .preview-wrap {
  background: #f6f9ff;
  border: 1rpx solid rgba(29, 50, 79, 0.14);
}

.theme-light .preview-placeholder {
  color: #71819a;
}
