.detail-page {
  min-height: 100vh;
  padding-bottom: 36rpx;
  box-sizing: border-box;
  background: #101114;
  position: relative;
  isolation: isolate;
  overflow-x: hidden;
}

.top-nav-wrap,
.top-nav,
.preview-section,
.entry-action,
.editor-panel {
  position: relative;
  z-index: 1;
}

.top-nav-wrap {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  pointer-events: none;
}

.top-nav {
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  padding: 0 28rpx;
  box-sizing: border-box;
  pointer-events: auto;
  background: transparent;
  border-bottom: none;
}

.preview-scroll {
  height: 100vh;
  box-sizing: border-box;
}

.detail-page.editor-open .preview-scroll {
  height: 44vh;
}

.preview-scroll::-webkit-scrollbar,
.tab-content::-webkit-scrollbar {
  width: 0;
  height: 0;
  color: transparent;
  display: none;
}

.back-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 0;
  background: transparent;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-arrow {
  width: 18rpx;
  height: 18rpx;
  border-left: 4rpx solid #f3f4f6;
  border-bottom: 4rpx solid #f3f4f6;
  transform: rotate(45deg);
  margin-left: 8rpx;
}

.preview-section {
  padding-top: 236rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  z-index: 10;
}

.preview-wrapper {
  width: 100%;
  display: flex;
  justify-content: center;
  align-items: flex-start;
  position: relative;
  z-index: 0;
}

.ticket-preview {
  width: 640rpx;
  height: 1024rpx;
  border-radius: 24rpx;
  background: transparent;
  box-shadow: none;
  border: none;
  position: relative;
  z-index: 0;
  overflow: hidden;
}

.ticket-preview.preview-draggable {
  box-shadow: none;
}

.ticket-preview-image {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
}

.ticket-preview-image.base {
  z-index: 1;
}

.ticket-preview-image.text {
  z-index: 2;
  pointer-events: none;
}

.ticket-preview-empty {
  position: absolute;
  inset: 0;
  z-index: 0;
  background:
    radial-gradient(circle at 14% 10%, rgba(89, 99, 122, 0.45) 0, rgba(89, 99, 122, 0) 36%),
    radial-gradient(circle at 86% 86%, rgba(58, 66, 84, 0.5) 0, rgba(58, 66, 84, 0) 38%),
    #12151a;
}

.drag-tip {
  position: absolute;
  left: 18rpx;
  right: 18rpx;
  bottom: 18rpx;
  height: 60rpx;
  border-radius: 999rpx;
  background: rgba(0, 0, 0, 0.46);
  color: #f3f4f6;
  font-size: 21rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 4;
  pointer-events: none;
}

.crop-mask-layer {
  position: absolute;
  inset: 0;
  pointer-events: none;
  z-index: 2;
}

.crop-mask-piece {
  position: absolute;
  background: rgba(6, 8, 11, 0.54);
  pointer-events: none;
}

.crop-frame {
  position: absolute;
  border: 2rpx solid rgba(255, 255, 255, 0.94);
  box-shadow: inset 0 0 0 1rpx rgba(0, 0, 0, 0.32);
  z-index: 3;
  pointer-events: none;
}

.crop-corner {
  position: absolute;
  width: 18rpx;
  height: 18rpx;
  border-color: #ffffff;
  border-style: solid;
  border-width: 0;
}

.crop-corner.lt {
  left: -2rpx;
  top: -2rpx;
  border-left-width: 4rpx;
  border-top-width: 4rpx;
}

.crop-corner.rt {
  right: -2rpx;
  top: -2rpx;
  border-right-width: 4rpx;
  border-top-width: 4rpx;
}

.crop-corner.rb {
  right: -2rpx;
  bottom: -2rpx;
  border-right-width: 4rpx;
  border-bottom-width: 4rpx;
}

.crop-corner.lb {
  left: -2rpx;
  bottom: -2rpx;
  border-left-width: 4rpx;
  border-bottom-width: 4rpx;
}

.entry-action {
  width: 500rpx;
  margin-top: 30rpx;
}

.entry-btn {
  width: 100%;
  box-shadow: none;
}

.editor-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9999;
  height: 56vh;
  min-height: 820rpx;
  background: #171a20;
  border-radius: 30rpx 30rpx 0 0;
  display: flex;
  flex-direction: column;
  box-shadow: 0 -16rpx 44rpx rgba(0, 0, 0, 0.46);
  border-top: 1rpx solid rgba(255, 255, 255, 0.08);
  transform: translateY(calc(100% + 24rpx));
  transition: transform 0.28s ease;
  pointer-events: none;
}

.editor-panel.open {
  transform: translateY(0);
  pointer-events: auto;
}

.panel-handle-row {
  padding-top: 10rpx;
  position: relative;
  flex-shrink: 0;
}

.panel-handle {
  width: 84rpx;
  height: 8rpx;
  background: #616977;
  margin: 0 auto;
}

.panel-action {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tab-row {
  display: flex;
  height: 86rpx;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.08);
  margin: 8rpx 18rpx 0;
  padding: 0 10rpx 0 12rpx;
}

.tab-navs {
  position: relative;
  display: flex;
  align-items: center;
  gap: 56rpx;
  height: 100%;
}

.tab-item {
  position: relative;
  min-width: auto;
  width: 72rpx;
  height: 84rpx;
  line-height: 84rpx;
  text-align: center;
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.6);
  padding: 0;
}

.tab-item.active {
  color: #f3f4f6;
  font-weight: 600;
}

.tab-indicator {
  position: absolute;
  left: 8rpx;
  bottom: 0;
  width: 56rpx;
  height: 5rpx;
  background: #ff6a2f;
  transition: transform 0.24s ease;
}

.tab-indicator.on-text {
  transform: translateX(0);
}

.tab-indicator.on-image {
  transform: translateX(128rpx);
}

.tab-indicator.on-bg {
  transform: translateX(384rpx);
}

.tab-indicator.on-font {
  transform: translateX(256rpx);
}

.panel-action-icon {
  width: 26rpx;
  height: 26rpx;
  border-top: 3rpx solid rgba(255, 255, 255, 0.82);
  border-right: 3rpx solid rgba(255, 255, 255, 0.82);
  transform: rotate(45deg);
  position: relative;
}

.panel-action-icon::before {
  content: '';
  position: absolute;
  left: -14rpx;
  top: 14rpx;
  width: 26rpx;
  height: 26rpx;
  border-left: 3rpx solid rgba(255, 255, 255, 0.82);
  border-bottom: 3rpx solid rgba(255, 255, 255, 0.82);
}

.tab-content {
  flex: 1;
  height: 0;
  min-height: 0;
  padding: 18rpx 28rpx;
  box-sizing: border-box;
}

.text-form {
  background: transparent;
  border: none;
  padding: 0;
  box-sizing: border-box;
}

.field-item {
  margin-bottom: 26rpx;
  display: block;
}

.field-item:last-child {
  margin-bottom: 0;
}

.field-item.combined-item {
  display: block;
}

.combined-fields {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
}

.combined-cell {
  flex: 1;
  min-width: 0;
}

.combined-picker {
  display: block;
}

.field-label-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 10rpx;
}

.field-label {
  width: auto;
  height: auto;
  line-height: 1.35;
  margin-bottom: 0;
  font-size: 22rpx;
  color: #f3f4f6;
  font-weight: 500;
}

.field-overflow-tip {
  font-size: 22rpx;
  color: #ff5757;
  line-height: 1.35;
}

.field-control {
  width: 100%;
}

.field-input {
  width: 100%;
  height: 84rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  border-radius: 0;
  border: none;
  background: rgba(255, 255, 255, 0.1);
  color: #f3f4f6;
  font-size: 28rpx;
}

.field-picker {
  width: 100%;
  height: 84rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  border-radius: 0;
  background: rgba(255, 255, 255, 0.1);
  color: #f3f4f6;
  font-size: 28rpx;
  line-height: 84rpx;
}

.picker-with-arrow {
  position: relative;
  padding-right: 48rpx;
}

.picker-with-arrow::after {
  content: '';
  position: absolute;
  right: 18rpx;
  top: 50%;
  margin-top: -6rpx;
  width: 0;
  height: 0;
  border-left: 8rpx solid transparent;
  border-right: 8rpx solid transparent;
  border-top: 12rpx solid rgba(255, 255, 255, 0.66);
}

.field-picker.placeholder {
  color: #8a93a3;
}

.field-input.textarea {
  min-height: 124rpx;
  padding: 14rpx 20rpx;
  line-height: 1.5;
}

.image-tab {
  background: transparent;
  border: none;
  padding: 0;
  box-sizing: border-box;
}

.font-tab {
  background: transparent;
  border: none;
  padding: 0;
  box-sizing: border-box;
}

.font-label {
  margin-bottom: 14rpx;
  font-size: 28rpx;
  color: #f3f4f6;
  font-weight: 500;
}

.font-options {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.font-option {
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(255, 255, 255, 0.56);
  color: rgba(255, 255, 255, 0.86);
  background: transparent;
  font-size: 26rpx;
  box-sizing: border-box;
}

.font-option.selected {
  border-color: #ffffff;
  background: #ffffff;
  color: #1a1d23;
}

.upload-entry {
  border: none;
  border-radius: 0;
  height: 180rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.1);
}

.upload-entry-title {
  margin-top: 0;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.64);
  font-weight: 500;
}

.slider-wrap {
  margin-top: 16rpx;
}

.slider-label {
  margin-bottom: 10rpx;
  font-size: 26rpx;
  color: #d7dbe3;
}

.bg-tab {
  background: transparent;
  border: none;
  padding: 0;
  box-sizing: border-box;
}

.color-label {
  margin-bottom: 14rpx;
  font-size: 28rpx;
  color: #f3f4f6;
  font-weight: 500;
}

.color-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  row-gap: 20rpx;
  column-gap: 20rpx;
}

.color-item {
  width: 100%;
  height: 68rpx;
  border-radius: 0;
  border: none;
  box-sizing: border-box;
  transition: transform 0.18s ease, box-shadow 0.18s ease;
}

.color-item.selected {
  transform: scale(1.04);
  box-shadow: 0 0 0 3rpx rgba(243, 244, 246, 0.82);
}

.panel-footer {
  padding: 16rpx 20rpx 24rpx;
  display: block;
  background: #171a20;
  flex-shrink: 0;
  border-top: none;
}

.footer-btn {
  width: 100%;
  border-radius: 0;
}

.footer-btn.single {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.full-preview-layer {
  position: fixed;
  inset: 0;
  z-index: 12000;
  background: #090b0f;
  display: flex;
  align-items: center;
  justify-content: center;
}

.full-preview-image {
  width: 100vw;
  height: 100vh;
}

.full-preview-empty {
  width: 640rpx;
  height: 1024rpx;
  border-radius: 0;
  background: #15181e;
}

.route-mask {
  position: fixed;
  inset: 0;
  background: rgba(12, 13, 16, 0.95);
  z-index: 99;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.route-loading {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(255, 255, 255, 0.16);
  border-top-color: #f2f3f6;
  animation: spin 0.8s linear infinite;
}

.route-text {
  margin-top: 16rpx;
  color: #a3aab7;
  font-size: 24rpx;
}

.render-canvas {
  position: fixed;
  left: -2000px;
  top: -2000px;
  width: 640rpx;
  height: 1024rpx;
  opacity: 0;
  pointer-events: none;
}

@keyframes spin {
  0% {
    transform: rotate(0deg);
  }
  100% {
    transform: rotate(360deg);
  }
}

/* 主题维护说明：调整深色配色时，请同步更新下方浅色覆盖。 */
.theme-light.detail-page {
  background: #f4f7fc;
  color: #000;
}

.theme-light.detail-page .back-btn {
  background: transparent;
}

.theme-light.detail-page .back-arrow {
  border-left-color: #000;
  border-bottom-color: #000;
}

.theme-light.detail-page .ticket-preview {
  background: transparent;
  box-shadow: none;
  border: none;
}

.theme-light.detail-page .ticket-preview.preview-draggable {
  box-shadow: none;
}

.theme-light.detail-page .ticket-preview-empty {
  background:
    radial-gradient(circle at 14% 10%, rgba(146, 168, 202, 0.36) 0, rgba(146, 168, 202, 0) 36%),
    radial-gradient(circle at 86% 86%, rgba(173, 191, 219, 0.44) 0, rgba(173, 191, 219, 0) 38%),
    #e8eef9;
}

.theme-light.detail-page .drag-tip {
  background: rgba(255, 255, 255, 0.72);
  color: rgba(0, 0, 0, 0.74);
}

.theme-light.detail-page .crop-mask-piece {
  background: rgba(18, 32, 53, 0.24);
}

.theme-light.detail-page .crop-frame {
  border-color: rgba(36, 54, 81, 0.95);
  box-shadow: inset 0 0 0 1rpx rgba(255, 255, 255, 0.8);
}

.theme-light.detail-page .crop-corner {
  border-color: rgba(36, 54, 81, 0.95);
}

.theme-light.detail-page .editor-panel,
.theme-light.detail-page .panel-footer {
  background: #f8fbff;
  border-top: 1rpx solid rgba(34, 55, 84, 0.1);
  box-shadow: 0 -16rpx 44rpx rgba(26, 46, 74, 0.14);
}

.theme-light.detail-page .panel-handle {
  background: #a0afc5;
}

.theme-light.detail-page .tab-row {
  border-bottom: 1rpx solid rgba(31, 53, 82, 0.12);
}

.theme-light.detail-page .tab-item {
  color: rgba(0, 0, 0, 0.6);
}

.theme-light.detail-page .tab-item.active,
.theme-light.detail-page .field-label,
.theme-light.detail-page .color-label,
.theme-light.detail-page .font-label {
  color: #000;
}

.theme-light.detail-page .panel-action-icon {
  border-top-color: rgba(0, 0, 0, 0.82);
  border-right-color: rgba(0, 0, 0, 0.82);
}

.theme-light.detail-page .panel-action-icon::before {
  border-left-color: rgba(0, 0, 0, 0.82);
  border-bottom-color: rgba(0, 0, 0, 0.82);
}

.theme-light.detail-page .field-input,
.theme-light.detail-page .field-picker,
.theme-light.detail-page .upload-entry {
  background: rgba(39, 58, 88, 0.08);
  color: #000;
}

.theme-light.detail-page .font-option {
  border-color: rgba(0, 0, 0, 0.34);
  color: rgba(0, 0, 0, 0.76);
}

.theme-light.detail-page .font-option.selected {
  border-color: #000;
  background: #000;
  color: #fff;
}

.theme-light.detail-page .picker-with-arrow::after {
  border-top-color: rgba(0, 0, 0, 0.55);
}

.theme-light.detail-page .field-picker.placeholder,
.theme-light.detail-page .upload-entry-title {
  color: rgba(0, 0, 0, 0.5);
}

.theme-light.detail-page .slider-label {
  color: rgba(0, 0, 0, 0.66);
}

.theme-light.detail-page .field-input::placeholder,
.theme-light.detail-page .field-picker.placeholder,
.theme-light.detail-page .upload-entry-title,
.theme-light.detail-page textarea::placeholder {
  color: rgba(0, 0, 0, 0.45);
}

.theme-light.detail-page .color-item.selected {
  box-shadow: 0 0 0 3rpx rgba(37, 56, 84, 0.62);
}

.theme-light.detail-page .full-preview-layer {
  background: #eef3fb;
}

.theme-light.detail-page .full-preview-empty {
  background: #f5f8ff;
}

.theme-light.detail-page .route-mask {
  background: rgba(237, 244, 253, 0.95);
}

.theme-light.detail-page .route-text {
  color: rgba(0, 0, 0, 0.6);
}

.theme-light.detail-page .route-loading {
  border: 6rpx solid rgba(0, 0, 0, 0.16);
  border-top-color: rgba(0, 0, 0, 0.66);
}

.theme-light.detail-page .entry-btn {
  background: #000;
  color: #fff;
  box-shadow: none;
}
